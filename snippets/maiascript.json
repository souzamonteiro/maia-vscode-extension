{
  "Namespace": {
    "prefix": "namespace",
    "body": [
      "namespace ${1:name} {",
      "\t${2}",
      "}"
    ],
    "description": "Create a namespace"
  },
  "Function": {
    "prefix": "function",
    "body": [
      "function ${1:name}(${2:params}) {",
      "\t${3}",
      "}"
    ],
    "description": "Create a function"
  },
  "Plain Function": {
    "prefix": "plain",
    "body": [
      "plain ${1:name}(${2:params}) {",
      "\t${3}",
      "}"
    ],
    "description": "Create a plain function"
  },
  "Async Function": {
    "prefix": "async",
    "body": [
      "async ${1:name}(${2:params}) {",
      "\t${3}",
      "}"
    ],
    "description": "Create an async function"
  },
  "If Statement": {
    "prefix": "if",
    "body": [
      "if (${1:condition}) {",
      "\t${2}",
      "}"
    ],
    "description": "Create an if statement"
  },
  "If Else Statement": {
    "prefix": "ifelse",
    "body": [
      "if (${1:condition}) {",
      "\t${2}",
      "} else {",
      "\t${3}",
      "}"
    ],
    "description": "Create an if-else statement"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for (${1:i} = 0; ${1:i} < ${2:limit}; ${1:i} = ${1:i} + 1) {",
      "\t${3}",
      "}"
    ],
    "description": "Create a for loop"
  },
  "Foreach Loop": {
    "prefix": "foreach",
    "body": [
      "foreach (${1:collection}; ${2:key}; ${3:value}) {",
      "\t${4}",
      "}"
    ],
    "description": "Create a foreach loop"
  },
  "Global Declaration": {
    "prefix": "global",
    "body": [
      "global ${1:expression}"
    ],
    "description": "Create a global declaration"
  },
  "Local Declaration": {
    "prefix": "local",
    "body": [
      "local ${1:expression}"
    ],
    "description": "Create a local declaration"
  },
  "Test Block": {
    "prefix": "test",
    "body": [
      "test (${1:setup}; ${2:condition}; ${3:teardown}) {",
      "\t${4}",
      "} catch (${5:error}) {",
      "\t${6}",
      "}"
    ],
    "description": "Create a test block"
  },
  "Try Catch": {
    "prefix": "try",
    "body": [
      "try {",
      "\t${1}",
      "} catch (${2:err}) {",
      "\t${3}",
      "}"
    ],
    "description": "Create a try-catch block"
  }
}