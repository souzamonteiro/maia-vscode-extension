{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MaiaScript",
  "scopeName": "source.maiascript",
  "fileTypes": ["maia", "maiascript"],
  "patterns": [
    {
      "include": "#meta"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#brackets"
    },
    {
      "include": "#variables"
    }
  ],
  "repository": {
    "meta": {
      "patterns": [
        {
          "name": "comment.line.shebang.maia",
          "match": "^#!.*$"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.documentation.maia",
          "match": "///.*$"
        },
        {
          "name": "comment.line.number-sign.maia",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.maia",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.maia",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.maia",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.maia",
      "match": "\\b-?[0-9]+(\\.[0-9]+)?((e|E)(\\+|-)?[0-9]+)?\\b"
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.namespace.maia",
          "match": "\\b(namespace)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.maia"
            },
            "2": {
              "name": "entity.name.type.namespace.maia"
            }
          }
        },
        {
          "name": "meta.declaration.function.maia",
          "match": "\\b(async|function|plain)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.maia"
            },
            "2": {
              "name": "entity.name.function.maia"
            }
          }
        },
        {
          "name": "meta.declaration.function.typed.maia",
          "match": "\\b(i32|i64|f32|f64)\\s+([a-zA-Z_$][a-zA-Z0-9_$]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "storage.type.maia"
            },
            "2": {
              "name": "entity.name.function.maia"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.maia",
          "match": "(\\*\\*=)|(<<=)|(>>=)|(\\+=)|(-=)|(\\*=)|(/=)|(%=)|(&=)|(\\^=)|(\\|=)|(\\?=)|(:=)|(=)"
        },
        {
          "name": "keyword.operator.arithmetic.maia",
          "match": "(\\+\\+)|(--)|(\\*\\*)|(\\+)|(-)|(\\*)|(/)|(%)"
        },
        {
          "name": "keyword.operator.logical.maia",
          "match": "(\\|\\|)|(\\^\\^)|(&&)|(!)|(~)"
        },
        {
          "name": "keyword.operator.relational.maia",
          "match": "(==)|(!=)|(<=)|(>=)|(<)|(>)"
        },
        {
          "name": "keyword.operator.bitwise.maia",
          "match": "(<<)|(>>)|(\\|)|(\\^)|(&)"
        },
        {
          "name": "keyword.operator.ternary.maia",
          "match": "(\\?)|(:)"
        }
      ]
    },
    "brackets": {
      "patterns": [
        {
          "name": "punctuation.definition.bracket.curly.maia",
          "match": "\\{|\\}"
        },
        {
          "name": "punctuation.definition.bracket.square.maia",
          "match": "\\[|\\]"
        },
        {
          "name": "punctuation.definition.bracket.parenthesis.maia",
          "match": "\\(|\\)"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.maia",
          "match": "\\b(break|continue|do|else|elseif|for|foreach|if|return|switch|while|try|catch|throw|test|case|default)\\b"
        },
        {
          "name": "keyword.declaration.maia",
          "match": "\\b(namespace|function|plain|async|include|global|local|export|import)\\b"
        },
        {
          "name": "keyword.type.maia",
          "match": "\\b(i32|i64|f32|f64|null|true|false)\\b"
        },
        {
          "name": "keyword.other.maia",
          "match": "\\b(typeof)\\b"
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "name": "variable.other.maia",
          "match": "\\b[a-zA-Z_$][a-zA-Z0-9_$]*\\b(?=\\s*[=;,)])"
        },
        {
          "match": "(\\.)([a-zA-Z_$][a-zA-Z0-9_$]*)\\b",
          "captures": {
            "1": {
              "name": "punctuation.accessor.maia"
            },
            "2": {
              "name": "variable.other.maia"
            }
          }
        }
      ]
    }
  }
}