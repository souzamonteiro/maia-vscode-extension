{
  "$schema": "vscode://schemas/color-theme",
  "name": "MaiaScript Theme",
  "type": "dark",
  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#d4d4d4",
    "editor.lineHighlightBackground": "#2a2a2a",
    "editor.selectionBackground": "#264f78",
    "editor.inactiveSelectionBackground": "#3a3d41",
    "editorCursor.foreground": "#aeafad",
    "editorWhitespace.foreground": "#3b3b3b",
    "editorIndentGuide.background": "#404040",
    "editorIndentGuide.activeBackground": "#707070"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "comment.line.double-slash",
        "comment.line.double-slash.maia",
        "comment.line.number-sign.maia",
        "comment.line.documentation.maia",
        "comment.line.shebang.maia",
        "comment.block.maia"
      ],
      "settings": {
        "foreground": "#6a9955",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted.double",
        "string.quoted.double.maia",
        "string.quoted.single.maia"
      ],
      "settings": {
        "foreground": "#ce9178"
      }
    },
    {
      "name": "Numbers",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "name": "Keywords - Control Flow",
      "scope": ["keyword.control", "keyword.control.maia"],
      "settings": {
        "foreground": "#c586c0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keywords - Declaration",
      "scope": ["keyword.declaration", "keyword.declaration.maia"],
      "settings": {
        "foreground": "#569cd6",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keywords - Types",
      "scope": ["keyword.type", "keyword.type.maia"],
      "settings": {
        "foreground": "#4ec9b0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keywords - Other",
      "scope": ["keyword.other", "keyword.other.maia"],
      "settings": {
        "foreground": "#9cdcfe"
      }
    },
    {
      "name": "Operators - Assignment",
      "scope": "keyword.operator.assignment",
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "name": "Operators - Arithmetic",
      "scope": "keyword.operator.arithmetic",
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "name": "Operators - Logical",
      "scope": "keyword.operator.logical",
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "name": "Operators - Relational",
      "scope": "keyword.operator.relational",
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "name": "Operators - Bitwise",
      "scope": "keyword.operator.bitwise",
      "settings": {
        "foreground": "#d4d4d4"
      }
    },
    {
      "name": "Brackets - Curly",
      "scope": "punctuation.definition.bracket.curly",
      "settings": {
        "foreground": "#ffd700"
      }
    },
    {
      "name": "Brackets - Square",
      "scope": "punctuation.definition.bracket.square",
      "settings": {
        "foreground": "#ffd700"
      }
    },
    {
      "name": "Brackets - Parenthesis",
      "scope": "punctuation.definition.bracket.parenthesis",
      "settings": {
        "foreground": "#ffd700"
      }
    },
    {
      "name": "Namespace name",
      "scope": ["entity.name.type.namespace", "entity.name.type.namespace.maia"],
      "settings": {
        "foreground": "#4ec9b0",
        "fontStyle": "bold underline"
      }
    },
    {
      "name": "Function name",
      "scope": ["entity.name.function", "entity.name.function.maia"],
      "settings": {
        "foreground": "#dcdcaa",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable.other", "variable.other.maia"],
      "settings": {
        "foreground": "#9cdcfe"
      }
    }
  ]
}